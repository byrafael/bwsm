{
  "name": "bwsm-cli",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byrafael/bwsm.git"
  },
  "bugs": {
    "url": "https://github.com/byrafael/bwsm/issues"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": "^1.3.11",
    "node": "^25.2.1"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "bwsm": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "sizecheck": "node scripts/check-dist-size.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && node --import tsx --test"
  },
  "dependencies": {
    "@bitwarden/sdk-napi": "^1.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
